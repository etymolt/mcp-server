{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.etymolt/mcp-server",
  "description": "Brand-name verification MCP \u2014 five-axis signed verdicts for AI-generated names.",
  "title": "Etymolt",
  "version": "2.1.0",
  "repository": {
    "url": "https://github.com/etymolt/mcp-server",
    "source": "github"
  },
  "websiteUrl": "https://etymolt.com",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@etymolt/mcp-server",
      "version": "2.1.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        },
        {
          "type": "positional",
          "value": "@etymolt/mcp-server"
        }
      ]
    }
  ]
}
